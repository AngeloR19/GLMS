@model GLMS_POE.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2 class="mb-4">📊 GLMS Dashboard</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card text-white mb-3 shadow" style="background:#4e73df;">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Clients</h5>
                            <h2>@Model.TotalClients</h2>
                            <p class="card-text">Total registered clients</p>
                            <p class="card-text">Manage all registered clients.</p>

                            <a asp-controller="Client"
                                   asp-action="Index"
                                   class="btn btn-light btn-sm">
                                View
                            </a>
                        </div>

                        <i class="bi bi-people-fill" style="font-size:2.5rem;"></i>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white mb-3 shadow" style="background:#1cc88a;">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Contracts</h5>
                            <h2>@Model.TotalContracts</h2>
                            <p class="card-text">Total contracts in system</p>
                            <p class="card-text">Track active and expired contracts.</p>

                            <a asp-controller="Contract"
                                   asp-action="Index"
                                   class="btn btn-light btn-sm">
                                View
                            </a>
                        </div>

                        <i class="bi bi-file-earmark-text-fill" style="font-size:2.5rem;"></i>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white mb-3 shadow" style="background:#f6c23e;">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title">Service Requests</h5>
                            <h2>@Model.TotalServiceRequests</h2>
                            <p class="card-text">Total service requests</p>
                            <p class="card-text">Monitor service request activity.</p>

                            <a asp-controller="ServiceRequest"
                                   asp-action="Index"
                                   class="btn btn-light btn-sm">
                                View
                            </a>
                        </div>

                        <i class="bi bi-gear-fill" style="font-size:2.5rem;"></i>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
