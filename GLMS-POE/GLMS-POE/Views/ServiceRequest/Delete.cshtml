@model GLMS_POE.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1>Delete Service Request</h1>

<h3>Are you sure you want to delete this service request?</h3>

<div>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Client
        </dt>
        <dd class="col-sm-10">
            @(Model.ClientName ?? "Unknown Client")
        </dd>

        <dt class="col-sm-2">
            Contract ID
        </dt>
        <dd class="col-sm-10">
            @Model.ContractId
        </dd>

        <dt class="col-sm-2">
            Description
        </dt>
        <dd class="col-sm-10">
            @Model.Description
        </dd>

        <dt class="col-sm-2">
            Currency
        </dt>
        <dd class="col-sm-10">
            @Model.CurrencyCode
        </dd>

        <dt class="col-sm-2">
            Foreign Cost
        </dt>
        <dd class="col-sm-10">
            @Model.CostForeign
        </dd>

        <dt class="col-sm-2">
            Cost (ZAR)
        </dt>
        <dd class="col-sm-10">
            @Model.CostZAR
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.Status
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <input type="submit"
               value="Delete"
               class="btn btn-danger rounded-pill px-4" />

        <a asp-action="Index"
               class="btn btn-light border rounded-pill px-4">
            Back to List
        </a>
    </form>
</div>
