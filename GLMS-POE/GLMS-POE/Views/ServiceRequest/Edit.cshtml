@model GLMS_POE.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<h1>Edit Service Request</h1>

<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit" method="post">

            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CostZAR" />

            <div class="form-group mb-2">
                <label asp-for="ContractId" class="control-label"></label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="CurrencyCode" class="control-label"></label>
                <select asp-for="CurrencyCode" class="form-control">
                    <option value="">-- Select Currency --</option>
                    <option value="ZAR">ZAR</option>
                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                    <option value="GBP">GBP</option>
                </select>
                <span asp-validation-for="CurrencyCode" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="CostForeign" class="control-label"></label>
                <input asp-for="CostForeign" class="form-control" />
                <span asp-validation-for="CostForeign" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="">-- Select Status --</option>
                    <option>Active</option>
                    <option>Expired</option>
                    <option>On Hold</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit"
                       value="Save Changes"
                       class="btn btn-primary rounded-pill px-4" />

                <a asp-action="Index"
                       class="btn btn-light border rounded-pill px-4">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
