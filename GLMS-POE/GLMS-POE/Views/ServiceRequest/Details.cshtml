@model GLMS_POE.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

<div>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Client
        </dt>
        <dd class="col-sm-10">
            @(Model.ClientName ?? "Unknown Client")
        </dd>

        <dt class="col-sm-2">
            Contract ID
        </dt>
        <dd class="col-sm-10">
            @Model.ContractId
        </dd>

        <dt class="col-sm-2">
            Description
        </dt>
        <dd class="col-sm-10">
            @Model.Description
        </dd>

        <dt class="col-sm-2">
            Currency
        </dt>
        <dd class="col-sm-10">
            @Model.CurrencyCode
        </dd>

        <dt class="col-sm-2">
            Foreign Cost
        </dt>
        <dd class="col-sm-10">
            @Model.CostForeign
        </dd>

        <dt class="col-sm-2">
            Cost (ZAR)
        </dt>
        <dd class="col-sm-10">
            @Model.CostZAR
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.Status
        </dd>

    </dl>
</div>

<div class="mt-4">
    <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary rounded-pill px-4">
        Edit
    </a>

    <a asp-action="Index"
           class="btn btn-light border rounded-pill px-4">
        Back to List
    </a>
</div>
