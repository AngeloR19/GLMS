<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GLMS_POE</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GLMS_POE.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body class="bg-light">

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

            <div class="container-fluid d-flex">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    GLMS
                </a>

                <div class="mx-auto d-flex gap-4">

                    <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                        Home
                    </a>

                    <a class="nav-link text-white" asp-controller="Client" asp-action="Index">
                        Clients
                    </a>

                    <a class="nav-link text-white" asp-controller="Contract" asp-action="Index">
                        Contracts
                    </a>

                    <a class="nav-link text-white" asp-controller="ServiceRequest" asp-action="Index">
                        Service Requests
                    </a>

                </div>

                <div class="d-flex align-items-center">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link text-white"
                               asp-controller="Account"
                               asp-action="Logout">
                            Logout
                        </a>
                    }

                </div>

                <div style="width: 120px;"></div>

            </div>
        </nav>

    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - GLMS_POE -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
<!-- ///////////////////////////////////////// END OF FILE ///////////////////////////////////////// -->