@model GLMS_POE.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h1>Delete Contract</h1>

<h3>Are you sure you want to delete this contract?</h3>

<div>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Client
        </dt>
        <dd class="col-sm-10">
            @(Model.ClientName ?? Model.Client?.Name ?? "No Client")
        </dd>

        <dt class="col-sm-2">
            Start Date
        </dt>
        <dd class="col-sm-10">
            @Model.StartDate.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            End Date
        </dt>
        <dd class="col-sm-10">
            @Model.EndDate.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.Status
        </dd>

        <dt class="col-sm-2">
            Service Level
        </dt>
        <dd class="col-sm-10">
            @Model.ServiceLevel
        </dd>

        <dt class="col-sm-2">
            File
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <a asp-action="Download" asp-route-filePath="@Model.FilePath">
                    Download PDF
                </a>
            }
            else
            {
                <span class="text-muted">No file uploaded</span>
            }
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <input type="submit"
               value="Delete"
               class="btn btn-danger rounded-pill px-4" />

        <a asp-action="Index"
               class="btn btn-light border rounded-pill px-4">
            Back to List
        </a>
    </form>
</div>
