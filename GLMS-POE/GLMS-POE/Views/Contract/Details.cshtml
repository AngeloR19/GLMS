@model GLMS_POE.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h1>Contract Details</h1>

<div>
    <h4>Contract</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            Client
        </dt>
        <dd class="col-sm-10">
            @(Model.ClientName ?? Model.Client?.Name ?? "No Client")
        </dd>

        <dt class="col-sm-2">
            Start Date
        </dt>
        <dd class="col-sm-10">
            @Model.StartDate.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            End Date
        </dt>
        <dd class="col-sm-10">
            @Model.EndDate.ToShortDateString()
        </dd>

        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.Status
        </dd>

        <dt class="col-sm-2">
            Service Level
        </dt>
        <dd class="col-sm-10">
            @Model.ServiceLevel
        </dd>

        <dt class="col-sm-2">
            File
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <a asp-action="Download" asp-route-filePath="@Model.FilePath">
                    Download PDF
                </a>
            }
            else
            {
                <span class="text-muted">No file uploaded</span>
            }
        </dd>
    </dl>
</div>

<div class="mt-4">
    <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary rounded-pill px-4">
        Edit
    </a>

    <a asp-action="Index"
           class="btn btn-light border rounded-pill px-4">
        Back to List
    </a>
</div>
