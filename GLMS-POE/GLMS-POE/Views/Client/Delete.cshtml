@model GLMS_POE.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<h1>Delete Client</h1>

<h3>Are you sure you want to delete this client?</h3>

<div>
    <hr />

    <dl class="row">

        <dt class="col-sm-2">
            Name
        </dt>
        <dd class="col-sm-10">
            @Model.Name
        </dd>

        <dt class="col-sm-2">
            Email
        </dt>
        <dd class="col-sm-10">
            @Model.Email
        </dd>

        <dt class="col-sm-2">
            Phone Number
        </dt>
        <dd class="col-sm-10">
            @Model.PhoneNumber
        </dd>

        <dt class="col-sm-2">
            Region
        </dt>
        <dd class="col-sm-10">
            @Model.Region
        </dd>

    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <input type="submit"
               value="Delete"
               class="btn btn-danger rounded-pill px-4" />

        <a asp-action="Index"
               class="btn btn-light border rounded-pill px-4">
            Back to List
        </a>
    </form>
</div>
